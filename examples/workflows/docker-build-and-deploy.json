        "outputMode": "aggregate"
      },
      "id": "docker-build",
      "name": "Docker Build",
      "type": "@faithleysath/n8n-nodes-docker.dockerBuild",
      "typeVersion": 1,
      "position": [-220, 120],
      "credentials": {
