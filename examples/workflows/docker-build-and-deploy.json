      "typeVersion": 1,
      "position": [80, 40],
      "credentials": {
        "dockerApi": {
          "name": "Docker Deploy"
        }
      }
    },
    {
      "parameters": {
        "resource": "container",
        "operation": "start",
        "containerId": "demo-app"
