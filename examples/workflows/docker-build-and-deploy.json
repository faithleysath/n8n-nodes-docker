            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Docker Build": {
      "main": [
        [
          {
            "node": "Create Container",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Container": {
      "main": [
        [
          {
            "node": "Start Container",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
